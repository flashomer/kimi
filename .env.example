# Kimi 2.5 CLI Agent Configuration
# Kopyalayıp .env olarak kaydedin

# Moonshot API Key (https://platform.moonshot.ai adresinden alın)
MOONSHOT_API_KEY=your_api_key_here

# Redis URL (Docker Compose kullanıyorsanız değiştirmeyin)
REDIS_URL=redis://redis:6379

# Frontend API URL
VITE_API_URL=http://localhost:8000
